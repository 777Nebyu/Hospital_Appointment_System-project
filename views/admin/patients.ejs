<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/admin/patients' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-7xl mx-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-secondary-800">Manage Patients</h1>
                <p class="text-secondary-500 mt-1">View and manage patient records</p>
            </div>

            <% if (patients && patients.length > 0) { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-secondary-50 border-b border-secondary-200">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Name</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Email</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Phone</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Gender</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Blood Type</th>
                                    <th class="px-6 py-4 text-right text-xs font-medium text-secondary-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-secondary-100">
                                <% patients.forEach(function(patient) { %>
                                    <tr class="hover:bg-secondary-50 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center">
                                                <div class="w-10 h-10 bg-accent-100 rounded-lg flex items-center justify-center mr-3">
                                                    <i class="fas fa-user text-accent-600"></i>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-medium text-secondary-800"><%= patient.first_name %> <%= patient.last_name %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-secondary-600"><%= patient.email %></td>
                                        <td class="px-6 py-4 text-sm text-secondary-600"><%= patient.phone || 'N/A' %></td>
                                        <td class="px-6 py-4 text-sm text-secondary-600 capitalize"><%= patient.gender || 'N/A' %></td>
                                        <td class="px-6 py-4 text-sm text-secondary-600"><%= patient.blood_type || 'N/A' %></td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end space-x-2">
                                                <a href="/admin/patients/edit/<%= patient.pid %>" class="text-primary-600 hover:text-primary-800 text-sm font-medium transition-colors" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <form action="/admin/patients/delete/<%= patient.pid %>" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this patient?');">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium transition-colors" title="Delete">
                                                        <i class="fas fa-trash-alt"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 p-12 text-center">
                    <div class="w-20 h-20 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-users text-secondary-400 text-3xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-secondary-800 mb-2">No patients yet</h3>
                    <p class="text-secondary-500">Patients will appear here when they register.</p>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>