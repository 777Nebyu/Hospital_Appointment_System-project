<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/doctor/appointments' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-7xl mx-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-secondary-800">Appointments</h1>
                <p class="text-secondary-500 mt-1">Manage and review your patient appointments</p>
            </div>

            <% if (appointments && appointments.length > 0) { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-secondary-50 border-b border-secondary-200">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Patient</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Date & Time</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Reason</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-4 text-right text-xs font-medium text-secondary-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-secondary-100">
                                <% appointments.forEach(function(apt) { %>
                                    <tr class="hover:bg-secondary-50 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center">
                                                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mr-3">
                                                    <i class="fas fa-user text-primary-600"></i>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-medium text-secondary-800"><%= apt.patient_first_name %> <%= apt.patient_last_name %></p>
                                                    <p class="text-xs text-secondary-500"><%= apt.patient_phone || 'No phone' %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-sm text-secondary-800"><%= new Date(apt.appointment_date).toLocaleDateString() %></p>
                                            <p class="text-xs text-secondary-500"><%= apt.appointment_time %></p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-sm text-secondary-600 max-w-xs truncate"><%= apt.reason %></p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-3 py-1 rounded-full text-xs font-medium status-<%= apt.status %>">
                                                <%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <div class="flex items-center justify-end space-x-2">
                                                <a href="/doctor/patients/<%= apt.patient_id %>" class="text-primary-600 hover:text-primary-800 text-sm font-medium transition-colors" title="View Patient Info">
                                                    <i class="fas fa-user-circle"></i>
                                                </a>
                                                <% if (apt.status === 'pending') { %>
                                                    <form action="/doctor/appointments/<%= apt.aid %>/approve" method="POST" class="inline">
                                                        <button type="submit" class="text-green-600 hover:text-green-800 text-sm font-medium transition-colors" title="Approve">
                                                            <i class="fas fa-check-circle"></i>
                                                        </button>
                                                    </form>
                                                    <form action="/doctor/appointments/<%= apt.aid %>/reject" method="POST" class="inline">
                                                        <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium transition-colors" title="Reject">
                                                            <i class="fas fa-times-circle"></i>
                                                        </button>
                                                    </form>
                                                <% } else if (apt.status === 'approved') { %>
                                                    <form action="/doctor/appointments/<%= apt.aid %>/complete" method="POST" class="inline">
                                                        <button type="submit" class="text-blue-600 hover:text-blue-800 text-sm font-medium transition-colors" title="Complete">
                                                            <i class="fas fa-check-double"></i>
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 p-12 text-center">
                    <div class="w-20 h-20 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-calendar text-secondary-400 text-3xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-secondary-800 mb-2">No appointments yet</h3>
                    <p class="text-secondary-500">You don't have any appointments scheduled.</p>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>