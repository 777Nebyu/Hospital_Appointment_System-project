<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/doctor/appointments' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-3xl mx-auto">
            <div class="mb-8">
                <a href="/doctor/appointments" class="text-sm text-primary-600 hover:text-primary-700 font-medium mb-2 inline-block">
                    <i class="fas fa-arrow-left mr-1"></i> Back to Appointments
                </a>
                <h1 class="text-3xl font-bold text-secondary-800">Patient Information</h1>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-secondary-100 overflow-hidden">
                <div class="h-24 bg-gradient-to-r from-primary-500 to-primary-600"></div>
                <div class="px-8 pb-8">
                    <div class="relative -mt-12 mb-6">
                        <div class="w-24 h-24 bg-white rounded-full border-4 border-white shadow-lg flex items-center justify-center">
                            <i class="fas fa-user text-primary-500 text-4xl"></i>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Full Name</label>
                            <p class="text-lg font-semibold text-secondary-800"><%= patient.first_name %> <%= patient.last_name %></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Email</label>
                            <p class="text-lg text-secondary-800"><%= patient.email %></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Phone</label>
                            <p class="text-lg text-secondary-800"><%= patient.phone || 'Not provided' %></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Date of Birth</label>
                            <p class="text-lg text-secondary-800"><%= patient.date_of_birth ? new Date(patient.date_of_birth).toLocaleDateString() : 'Not provided' %></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Gender</label>
                            <p class="text-lg text-secondary-800 capitalize"><%= patient.gender || 'Not provided' %></p>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Blood Type</label>
                            <p class="text-lg text-secondary-800"><%= patient.blood_type || 'Not provided' %></p>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Address</label>
                            <p class="text-lg text-secondary-800"><%= patient.address || 'Not provided' %></p>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-secondary-500 mb-1">Emergency Contact</label>
                            <p class="text-lg text-secondary-800"><%= patient.emergency_contact || 'Not provided' %></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>