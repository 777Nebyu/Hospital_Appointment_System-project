<!-- Navigation -->
<nav class="bg-white shadow-sm border-b border-secondary-200 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <!-- Logo -->
            <div class="flex items-center">
                <a href="/" class="flex items-center space-x-2">
                    <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center">
                        <i class="fas fa-hospital-alt text-white text-lg"></i>
                    </div>
                    <span class="text-xl font-bold text-secondary-800">Medi<span class="text-primary-600">Care</span></span>
                </a>
            </div>

            <!-- Desktop Navigation -->
            <div class="hidden md:flex items-center space-x-1">
                <a href="/" class="px-3 py-2 rounded-md text-sm font-medium text-secondary-600 hover:text-primary-600 hover:bg-primary-50 transition-colors">Home</a>
               
                <% if (user) { %>
                    <div class="relative ml-4 group">
                        <button class="flex items-center space-x-2 px-3 py-2 rounded-md text-sm font-medium text-secondary-700 hover:bg-secondary-100 transition-colors">
                            <div class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center">
                                <i class="fas fa-user text-primary-600 text-sm"></i>
                            </div>
                            <span><%= user.email %></span>
                            <i class="fas fa-chevron-down text-xs text-secondary-400"></i>
                        </button>
                        <div class="absolute right-0 mt-0 w-48 bg-white rounded-lg shadow-lg border border-secondary-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                            <a href="/dashboard" class="block px-4 py-2 text-sm text-secondary-700 hover:bg-primary-50 hover:text-primary-600 rounded-t-lg">
                                <i class="fas fa-tachometer-alt mr-2"></i>Dashboard
                            </a>
                            <a href="/auth/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-b-lg">
                                <i class="fas fa-sign-out-alt mr-2"></i>Logout
                            </a>
                        </div>
                    </div>
                <% } else { %>
                    <a href="/auth/login" class="ml-4 px-4 py-2 rounded-lg text-sm font-medium text-primary-600 border border-primary-600 hover:bg-primary-50 transition-colors">Login</a>
                    <a href="/auth/register" class="ml-2 px-4 py-2 rounded-lg text-sm font-medium text-white btn-primary transition-colors">Register</a>
                <% } %>
            </div>

            <!-- Mobile menu button -->
            <div class="flex items-center md:hidden">
                <button onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" class="p-2 rounded-md text-secondary-600 hover:text-primary-600 hover:bg-primary-50">
                    <i class="fas fa-bars text-xl"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-secondary-200">
        <div class="px-2 pt-2 pb-3 space-y-1">
            <a href="/" class="block px-3 py-2 rounded-md text-base font-medium text-secondary-600 hover:text-primary-600 hover:bg-primary-50">Home</a>
             <% if (user) { %>
                <a href="/dashboard" class="block px-3 py-2 rounded-md text-base font-medium text-secondary-600 hover:text-primary-600 hover:bg-primary-50">Dashboard</a>
                <a href="/auth/logout" class="block px-3 py-2 rounded-md text-base font-medium text-red-600 hover:bg-red-50">Logout</a>
            <% } else { %>
                <a href="/auth/login" class="block px-3 py-2 rounded-md text-base font-medium text-primary-600">Login</a>
                <a href="/auth/register" class="block px-3 py-2 rounded-md text-base font-medium text-white btn-primary">Register</a>
            <% } %>
        </div>
    </div>
</nav>
