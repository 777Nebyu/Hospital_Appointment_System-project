<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/patient/appointments' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-secondary-800">My Appointments</h1>
                    <p class="text-secondary-500 mt-1">View and manage your appointment history</p>
                </div>
                <a href="/patient/book-appointment" class="px-4 py-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white rounded-lg text-sm font-medium hover:from-primary-600 hover:to-primary-700 transition-colors shadow-md">
                    <i class="fas fa-plus mr-2"></i> New Appointment
                </a>
            </div>

            <% if (appointments && appointments.length > 0) { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-secondary-50 border-b border-secondary-200">
                                <tr>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Doctor</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Date & Time</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Reason</th>
                                    <th class="px-6 py-4 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Status</th>
                                    <th class="px-6 py-4 text-right text-xs font-medium text-secondary-500 uppercase tracking-wider">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-secondary-100">
                                <% appointments.forEach(function(apt) { %>
                                    <tr class="hover:bg-secondary-50 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center">
                                                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mr-3">
                                                    <i class="fas fa-user-md text-primary-600"></i>
                                                </div>
                                                <div>
                                                    <p class="text-sm font-medium text-secondary-800">Dr. <%= apt.doctor_first_name %> <%= apt.doctor_last_name %></p>
                                                    <p class="text-xs text-secondary-500"><%= apt.specialization %></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-sm text-secondary-800"><%= new Date(apt.appointment_date).toLocaleDateString() %></p>
                                            <p class="text-xs text-secondary-500"><%= apt.appointment_time %></p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <p class="text-sm text-secondary-600 max-w-xs truncate"><%= apt.reason %></p>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-3 py-1 rounded-full text-xs font-medium status-<%= apt.status %>">
                                                <%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-right">
                                            <% if (apt.status === 'pending' || apt.status === 'approved') { %>
                                                <form action="/patient/appointments/<%= apt.aid %>/cancel" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to cancel this appointment?');">
                                                    <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-medium transition-colors">
                                                        <i class="fas fa-times-circle mr-1"></i> Cancel
                                                    </button>
                                                </form>
                                            <% } else { %>
                                                <span class="text-secondary-400 text-sm">-</span>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } else { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 p-12 text-center">
                    <div class="w-20 h-20 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-calendar text-secondary-400 text-3xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-secondary-800 mb-2">No appointments yet</h3>
                    <p class="text-secondary-500 mb-6">You haven't booked any appointments yet.</p>
                    <a href="/patient/book-appointment" class="inline-flex items-center px-6 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white rounded-lg text-sm font-medium hover:from-primary-600 hover:to-primary-700 transition-colors shadow-md">
                        <i class="fas fa-calendar-plus mr-2"></i> Book Your First Appointment
                    </a>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>