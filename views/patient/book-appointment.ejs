<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/patient/book-appointment' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-3xl mx-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-secondary-800">Book Appointment</h1>
                <p class="text-secondary-500 mt-1">Schedule your visit with a healthcare professional</p>
            </div>

            <div class="bg-white rounded-xl shadow-sm border border-secondary-100 p-8">
                <form action="/patient/book-appointment" method="POST" class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-secondary-700 mb-1">Select Doctor *</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-user-md text-secondary-400"></i>
                            </div>
                            <select name="doctorId" required class="block w-full pl-10 pr-3 py-3 border border-secondary-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm">
                                <option value="">Choose a doctor...</option>
                                <% doctors.forEach(function(doctor) { %>
                                    <option value="<%= doctor.did %>" <%= selectedDoctor && selectedDoctor.did == doctor.did ? 'selected' : '' %>>
                                        Dr. <%= doctor.first_name %> <%= doctor.last_name %> - <%= doctor.specialization %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-secondary-700 mb-1">Appointment Date *</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-calendar text-secondary-400"></i>
                                </div>
                                <input type="date" name="appointmentDate" required min="<%= new Date().toISOString().split('T')[0] %>"
                                    class="block w-full pl-10 pr-3 py-3 border border-secondary-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-secondary-700 mb-1">Appointment Time *</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-clock text-secondary-400"></i>
                                </div>
                                <input type="time" name="appointmentTime" required
                                    class="block w-full pl-10 pr-3 py-3 border border-secondary-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm">
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-secondary-700 mb-1">Reason for Visit *</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 pt-3 flex items-start pointer-events-none">
                                <i class="fas fa-comment-medical text-secondary-400"></i>
                            </div>
                            <textarea name="reason" required rows="4" placeholder="Describe your symptoms or reason for the appointment..."
                                class="block w-full pl-10 pr-3 py-3 border border-secondary-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm resize-none"></textarea>
                        </div>
                    </div>

                    <div class="flex items-center justify-end space-x-4 pt-4">
                        <a href="/patient/dashboard" class="px-6 py-3 border border-secondary-300 rounded-lg text-sm font-medium text-secondary-700 hover:bg-secondary-50 transition-colors">Cancel</a>
                        <button type="submit" class="px-6 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white rounded-lg text-sm font-medium hover:from-primary-600 hover:to-primary-700 transition-colors shadow-md">
                            <i class="fas fa-calendar-plus mr-2"></i> Book Appointment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
