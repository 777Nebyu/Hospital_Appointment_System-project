<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/patient/dashboard' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-7xl mx-auto">
            <!-- Welcome Header -->
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-secondary-800">Welcome back, <%= patient.first_name %>!</h1>
                <p class="text-secondary-500 mt-1">Here's what's happening with your health today.</p>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100 card-hover">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-calendar-check text-primary-600 text-xl"></i>
                        </div>
                        <span class="text-sm font-medium text-primary-600 bg-primary-50 px-2 py-1 rounded-full">Total</span>
                    </div>
                    <p class="text-3xl font-bold text-secondary-800"><%= stats.total %></p>
                    <p class="text-sm text-secondary-500">Appointments</p>
                </div>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100 card-hover">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-clock text-yellow-600 text-xl"></i>
                        </div>
                        <span class="text-sm font-medium text-yellow-700 bg-yellow-50 px-2 py-1 rounded-full">Pending</span>
                    </div>
                    <p class="text-3xl font-bold text-secondary-800"><%= stats.pending %></p>
                    <p class="text-sm text-secondary-500">Awaiting Approval</p>
                </div>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100 card-hover">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-check-circle text-green-600 text-xl"></i>
                        </div>
                        <span class="text-sm font-medium text-green-700 bg-green-50 px-2 py-1 rounded-full">Approved</span>
                    </div>
                    <p class="text-3xl font-bold text-secondary-800"><%= stats.approved %></p>
                    <p class="text-sm text-secondary-500">Upcoming</p>
                </div>
                <div class="bg-white rounded-xl p-6 shadow-sm border border-secondary-100 card-hover">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center">
                            <i class="fas fa-history text-blue-600 text-xl"></i>
                        </div>
                        <span class="text-sm font-medium text-blue-700 bg-blue-50 px-2 py-1 rounded-full">Completed</span>
                    </div>
                    <p class="text-3xl font-bold text-secondary-800"><%= stats.completed %></p>
                    <p class="text-sm text-secondary-500">Past Visits</p>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <a href="/patient/search-doctors" class="bg-gradient-to-br from-primary-500 to-primary-600 rounded-xl p-6 text-white shadow-lg hover:shadow-xl transition-shadow card-hover">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-xl font-bold mb-2">Find a Doctor</h3>
                            <p class="text-primary-100 text-sm">Search and book appointments with specialists</p>
                        </div>
                        <div class="w-14 h-14 bg-white bg-opacity-20 rounded-xl flex items-center justify-center">
                            <i class="fas fa-search text-white text-2xl"></i>
                        </div>
                    </div>
                </a>
                <a href="/patient/book-appointment" class="bg-gradient-to-br from-accent-500 to-accent-600 rounded-xl p-6 text-white shadow-lg hover:shadow-xl transition-shadow card-hover">
                    <div class="flex items-center justify-between">
                        <div>
                            <h3 class="text-xl font-bold mb-2">Book Appointment</h3>
                            <p class="text-accent-100 text-sm">Schedule your next visit quickly</p>
                        </div>
                        <div class="w-14 h-14 bg-white bg-opacity-20 rounded-xl flex items-center justify-center">
                            <i class="fas fa-calendar-plus text-white text-2xl"></i>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Recent Appointments -->
            <div class="bg-white rounded-xl shadow-sm border border-secondary-100">
                <div class="p-6 border-b border-secondary-100 flex items-center justify-between">
                    <h2 class="text-xl font-bold text-secondary-800">Recent Appointments</h2>
                    <a href="/patient/appointments" class="text-sm text-primary-600 hover:text-primary-700 font-medium">View All <i class="fas fa-arrow-right ml-1"></i></a>
                </div>
                <div class="p-6">
                    <% if (appointments && appointments.length > 0) { %>
                        <div class="space-y-4">
                            <% appointments.forEach(function(apt) { %>
                                <div class="flex items-center justify-between p-4 bg-secondary-50 rounded-lg">
                                    <div class="flex items-center space-x-4">
                                        <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center">
                                            <i class="fas fa-user-md text-primary-600 text-lg"></i>
                                        </div>
                                        <div>
                                            <p class="font-semibold text-secondary-800">Dr. <%= apt.doctor_first_name %> <%= apt.doctor_last_name %></p>
                                            <p class="text-sm text-secondary-500"><%= apt.specialization %></p>
                                            <p class="text-xs text-secondary-400"><i class="far fa-calendar mr-1"></i> <%= new Date(apt.appointment_date).toLocaleDateString() %> at <%= apt.appointment_time %></p>
                                        </div>
                                    </div>
                                    <span class="px-3 py-1 rounded-full text-xs font-medium status-<%= apt.status %>"><%= apt.status.charAt(0).toUpperCase() + apt.status.slice(1) %></span>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-8">
                            <div class="w-16 h-16 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                                <i class="fas fa-calendar text-secondary-400 text-2xl"></i>
                            </div>
                            <p class="text-secondary-500">No appointments yet. <a href="/patient/book-appointment" class="text-primary-600 font-medium">Book your first appointment</a></p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
