<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<div class="flex min-h-screen bg-secondary-50">
    <%- include('../partials/sidebar', { currentPath: '/patient/search-doctors' }) %>

    <main class="flex-1 p-6 lg:p-8 overflow-y-auto">
        <div class="max-w-7xl mx-auto">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-secondary-800">Find a Doctor</h1>
                <p class="text-secondary-500 mt-1">Search for specialists and book appointments</p>
            </div>

            <!-- Search Bar -->
            <div class="bg-white rounded-xl shadow-sm border border-secondary-100 p-6 mb-8">
                <form action="/patient/search-doctors" method="GET" class="flex flex-col md:flex-row gap-4">
                    <div class="flex-1">
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-search text-secondary-400"></i>
                            </div>
                            <input type="text" name="q" value="<%= searchQuery || '' %>" placeholder="Search by name or specialization..."
                                class="block w-full pl-10 pr-3 py-3 border border-secondary-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm">
                        </div>
                    </div>
                    <div class="md:w-64">
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-stethoscope text-secondary-400"></i>
                            </div>
                            <input type="text" name="specialization" value="<%= specializationFilter || '' %>" placeholder="Specialization..."
                                class="block w-full pl-10 pr-3 py-3 border border-secondary-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors text-sm">
                        </div>
                    </div>
                    <button type="submit" class="px-6 py-3 bg-gradient-to-r from-primary-500 to-primary-600 text-white rounded-lg text-sm font-medium hover:from-primary-600 hover:to-primary-700 transition-colors shadow-md">
                        <i class="fas fa-search mr-2"></i> Search
                    </button>
                </form>
            </div>

            <!-- Results -->
            <% if (doctors && doctors.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% doctors.forEach(function(doctor) { %>
                        <div class="bg-white rounded-xl shadow-sm border border-secondary-100 overflow-hidden card-hover">
                            <div class="h-20 bg-gradient-to-r from-primary-500 to-primary-600"></div>
                            <div class="px-6 pb-6">
                                <div class="relative -mt-10 mb-4 flex justify-center">
                                    <div class="w-20 h-20 bg-white rounded-full border-4 border-white shadow-lg flex items-center justify-center">
                                        <i class="fas fa-user-md text-primary-500 text-3xl"></i>
                                    </div>
                                </div>
                                <div class="text-center">
                                    <h3 class="text-lg font-bold text-secondary-800">Dr. <%= doctor.first_name %> <%= doctor.last_name %></h3>
                                    <p class="text-sm text-primary-600 font-medium mb-1"><%= doctor.specialization %></p>
                                    <p class="text-xs text-secondary-500 mb-3"><%= doctor.experience_years %> years experience</p>
                                    <% if (doctor.qualification) { %>
                                        <p class="text-xs text-secondary-400 mb-3"><i class="fas fa-graduation-cap mr-1"></i> <%= doctor.qualification %></p>
                                    <% } %>
                                    <div class="flex items-center justify-center space-x-2 mb-4">
                                        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                            <i class="fas fa-check-circle mr-1"></i> Available
                                        </span>
                                    </div>
                                    <a href="/patient/book-appointment?doctorId=<%= doctor.did %>" class="w-full inline-flex items-center justify-center px-4 py-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white rounded-lg text-sm font-medium hover:from-primary-600 hover:to-primary-700 transition-colors shadow-md">
                                        <i class="fas fa-calendar-plus mr-2"></i> Book Appointment
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="bg-white rounded-xl shadow-sm border border-secondary-100 p-12 text-center">
                    <div class="w-20 h-20 bg-secondary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-user-md text-secondary-400 text-3xl"></i>
                    </div>
                    <h3 class="text-lg font-bold text-secondary-800 mb-2">No doctors found</h3>
                    <p class="text-secondary-500">Try adjusting your search criteria or check back later.</p>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>
